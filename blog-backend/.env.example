# Local development environment variables
# Copy this file to .env and fill in your Neon connection string

# Neon PostgreSQL connection string
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Cloudinary (for image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin authentication
# Option A: store a plain password in your deployment platform's secret manager
ADMIN_PASSWORD=your-admin-password

# Option B: store a bcrypt hash instead of a plain password
# Generate hash: node -e "require('bcryptjs').hash('your_password', 12).then(console.log)"
# ADMIN_PASSWORD_HASH=$2b$12$...
JWT_SECRET=your-random-secret-string-at-least-32-chars

# (Optional) Your frontend URL — for CORS whitelist
# FRONTEND_URL=https://your-project.vercel.app

# Server port (Render sets this automatically)
# PORT=3001
